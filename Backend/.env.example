# Supabase Configuration
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# API Keys
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
BIRDEYE_API_KEY=
SOLANATRACKER_API_KEY=
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=

# Operator Telegram IDs (comma-separated integers)
TELEGRAM_OPERATOR_CHAT_IDS=
TELEGRAM_OPERATOR_USER_IDS=

# Wallet encryption — REQUIRED before enabling live trading
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WALLET_ENCRYPTION_SECRET=

# UPSTASH
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=redis://127.0.0.1:6379
RATELIMIT_STORAGE_URI=redis://localhost:6379
PORT=5000

# ClickHouse Analytics Pipeline
CLICKHOUSE_HOST=your-cluster.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_password_here
CLICKHOUSE_DATABASE=sifter-kys
CLICKHOUSE_SECURE=true

# Worker mode — set to true on Celery worker processes
WORKER_MODE=false

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=alerts@sifter.app
ADMIN_EMAIL=

# SMTP — alternative email delivery for paper trader daily digest
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
PAPER_TRADER_EMAIL_TO=

# ============================================================================
# TELEGRAM TRADING BOT
# ============================================================================

# Bot username (no @) — used for deep links (TRADE_/SESSION_/MAGIC_) in emails
TELEGRAM_BOT_USERNAME=SifterTradingBot

# UUID of the system user that owns the Elite 15 watchlist.
# REQUIRED — the security screen uses this as the canonical Elite allow-list.
ELITE_SYSTEM_USER_ID=

# Web dashboard URL (bot Login/Register/Reset buttons + email links)
DASHBOARD_URL=
MAGIC_LINK_BASE_URL=

# ── Bot execution mode ────────────────────────────────────────────────────
# safe_noop = record only, no funds | paper = simulated fills |
# devnet = REAL swaps on Solana devnet | live = REAL mainnet money.
# START with paper. Move to devnet to validate MEV/slippage/gas/fees for real.
BOT_EXECUTION_MODE=paper

# ── Solana / Jupiter (devnet + live) ──────────────────────────────────────
JUPITER_BASE_URL=https://quote-api.jup.ag
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# ── Platform fee (only applied when fee_config.enabled=true AND devnet/live) ─
PLATFORM_FEE_BPS=100
TREASURY_WALLET_ADDRESS=
TREASURY_TOKEN_ACCOUNT=

# ── LIVE-MODE SAFETY GATE ──────────────────────────────────────────────────
# Router REFUSES live mode (downgrades to safe_noop) unless this is true AND
# treasury + RPC + WALLET_ENCRYPTION_SECRET are all set. Flip ONLY at go-live.
LIVE_TRADING_CONFIRMED=false
