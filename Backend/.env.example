# Supabase Configuration
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# API Keys
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
BIRDEYE_API_KEY=
SOLANATRACKER_API_KEY=
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=

# Operator Telegram IDs (comma-separated integers)
TELEGRAM_OPERATOR_CHAT_IDS=
TELEGRAM_OPERATOR_USER_IDS=

# Wallet encryption — REQUIRED before enabling live trading
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WALLET_ENCRYPTION_SECRET=

# UPSTASH
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=redis://127.0.0.1:6379
RATELIMIT_STORAGE_URI=redis://localhost:6379
PORT=5000

# ClickHouse Analytics Pipeline
CLICKHOUSE_HOST=your-cluster.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_password_here
CLICKHOUSE_DATABASE=sifter-kys
CLICKHOUSE_SECURE=true

# Worker mode — set to true on Celery worker processes
WORKER_MODE=false

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=alerts@sifter.app
ADMIN_EMAIL=

# SMTP — alternative email delivery for paper trader daily digest
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
PAPER_TRADER_EMAIL_TO=
