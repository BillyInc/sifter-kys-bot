# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Data providers
SOLANATRACKER_API_KEY=your-solanatracker-key
BIRDEYE_API_KEY=your-birdeye-key
HELIUS_API_KEY=your-helius-key

# Server endpoints
API_BASE_URL=https://sifter-kys.duckdns.org

# Solana network: mainnet-beta or devnet
SOLANA_NETWORK=mainnet-beta

# Set to true to force devnet mode (overrides SOLANA_NETWORK)
DEVNET_MODE=false

# Optional: QuickNode WebSocket
QUICKNODE_WSS=wss://your-endpoint.quiknode.pro/your-key/

# Optional: Devnet RPC URL override
DEVNET_RPC_URL=https://api.devnet.solana.com
